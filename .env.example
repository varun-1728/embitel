# ---- LLM backend ----
# Which provider to use: gemini (default, free) | claude | groq
LLM_PROVIDER=gemini

# Google Gemini (free tier): get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# Optional: swap to Claude later by setting LLM_PROVIDER=claude and this key
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Groq (no built-in web search)
# GROQ_API_KEY=gsk_...

# ---- Gmail (weekly report delivery) ----
# The Gmail account the report is SENT FROM.
GMAIL_ADDRESS=you@gmail.com
# NOT your normal password. Create an App Password:
# https://myaccount.google.com/apppasswords  (requires 2-Step Verification on)
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop
